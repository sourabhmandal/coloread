# Copy this file to .env and fill in your values.

# OpenAI-compatible base URL (local llama.cpp/LM Studio/Ollama gateway etc.)
OPENAI_BASE_URL=http://127.0.0.1:8080/v1

# Optional API key for endpoints that require authentication.
# Local servers often ignore this and do not need a key.
OPENAI_API_KEY=

# Legacy fallback key name (optional).
GITHUB_TOKEN=

# Model to use for highlighting
OPENAI_MODEL=gemma-4-E2B-it-GGUF

# Maximum file size for PDF uploads in MB (default: 20)
MAX_UPLOAD_SIZE_MB=20
